{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "atlas": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini"
    },
    "hephaestus": {
      "model": "openai/gpt-5.5",
      "prompt_append": "You are the primary implementation agent. Own the codebase. Explore, decide, execute. Use LSP and AST-grep aggressively.",
      "variant": "medium"
    },
    "librarian": {
      "model": "openai/gpt-5.4-mini"
    },
    "metis": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.5",
      "prompt_append": "Focus on code quality, edge cases, and test coverage.",
      "variant": "xhigh"
    },
    "multimodal-looker": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high"
    },
    "oracle": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "prometheus": {
      "model": "openai/gpt-5.4-mini",
      "prompt_append": "Keep plans concise. Focus on file structure and key decisions.",
      "variant": "high"
    },
    "sisyphus": {
      "model": "openai/gpt-5.5",
      "prompt_append": "Delegate heavily to hephaestus for implementation. Parallelize exploration.",
      "variant": "medium"
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.4-mini",
      "variant": "medium"
    }
  },
  "background_task": {
    "defaultConcurrency": 8,
    "providerConcurrency": {
      "anthropic": 5,
      "github-copilot": 10,
      "google": 10,
      "openai": 5,
      "opencode": 15
    }
  },
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  "categories": {
    "artistry": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high"
    },
    "deep": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "quick": {
      "model": "openai/gpt-5.4-mini"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "visual-engineering": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high"
    },
    "writing": {
      "model": "openai/gpt-5.4-mini"
    }
  },
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true
  },
  "hashline_edit": true,
  "sisyphus": {
    "tasks": {
      "claude_code_compat": false
    }
  }
}
