{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "hashline_edit": true,
  "agents": {
    "sisyphus": {
      "model": "openrouter/deepseek/deepseek-v4-flash",
      "variant": "max"
    },
    "hephaestus": {
      "model": "openrouter/deepseek/deepseek-v4-flash",
      "variant": "max",
      "allow_non_gpt_model": true
    },
    "sisyphus-junior": {
      "model": "openrouter/deepseek/deepseek-v4-flash",
      "variant": "max"
    },
    "prometheus": {
      "model": "openrouter/deepseek/deepseek-v4-flash",
      "variant": "max"
    },
    "metis": {
      "model": "openrouter/deepseek/deepseek-v4-flash"
    },
    "momus": {
      "model": "openrouter/deepseek/deepseek-v4-flash"
    },
    "oracle": {
      "model": "openrouter/deepseek/deepseek-v4-flash",
      "variant": "max"
    },
    "librarian": {
      "model": "openrouter/deepseek/deepseek-v4-flash"
    },
    "explore": {
      "model": "openrouter/deepseek/deepseek-v4-flash"
    },
    "multimodal-looker": {
      "model": "openrouter/deepseek/deepseek-v4-flash"
    },
    "atlas": {
      "model": "openrouter/deepseek/deepseek-v4-flash"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "openrouter/deepseek/deepseek-v4-flash"
    },
    "ultrabrain": {
      "model": "openrouter/deepseek/deepseek-v4-flash",
      "variant": "max"
    },
    "deep": {
      "model": "openrouter/deepseek/deepseek-v4-flash",
      "variant": "max"
    },
    "artistry": {
      "model": "openrouter/deepseek/deepseek-v4-flash",
      "variant": "max"
    },
    "quick": {
      "model": "openrouter/deepseek/deepseek-v4-flash"
    },
    "unspecified-low": {
      "model": "openrouter/deepseek/deepseek-v4-flash"
    },
    "unspecified-high": {
      "model": "openrouter/deepseek/deepseek-v4-flash",
      "variant": "max"
    },
    "writing": {
      "model": "openrouter/deepseek/deepseek-v4-flash"
    }
  },
  "sisyphus_agent": {
    "planner_enabled": true,
    "replace_plan": true
  },
  "auto_update": true,
  "background_task": {
    "defaultConcurrency": 5,
    "providerConcurrency": {
      "openrouter": 15
    },
    "modelConcurrency": {
      "openrouter/deepseek/deepseek-v4-flash": 10
    }
  },
  "model_capabilities": {
    "enabled": true,
    "auto_refresh_on_start": true
  },
  "sisyphus": {
    "tasks": {
      "storage_path": ".sisyphus/tasks",
      "claude_code_compat": false
    }
  }
}