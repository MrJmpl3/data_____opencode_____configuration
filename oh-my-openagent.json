{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  "model_fallback": true,
  "hashline_edit": true,

  "background_task": {
    "defaultConcurrency": 5,
    "providerConcurrency": {
      "opencode-go": 5,
      "github-copilot": 3,
      "openai": 3,
      "opencode": 10
    }
  },

  "experimental": {
    "aggressive_truncation": true,
    "task_system": true
  },

  "agents": {
    "sisyphus": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high",
      "ultrawork": {
        "model": "opencode-go/deepseek-v4-flash",
        "variant": "max"
      },
      "prompt_append": "Delegate heavily to hephaestus for implementation. Parallelize exploration."
    },
    "oracle": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max",
      "thinking": {
        "type": "enabled"
      }
    },
    "librarian": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "medium"
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "low"
    },
    "multimodal-looker": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "medium"
    },
    "prometheus": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high",
      "prompt_append": "Always interview first. Validate scope before planning."
    },
    "metis": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high"
    },
    "momus": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high",
      "prompt_append": "Focus on code quality, edge cases, and test coverage."
    },
    "atlas": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "medium"
    },
    "sisyphus-junior": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "low"
    },
    "hephaestus": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high",
      "description": "Complex implementation, deep refactors and architectural-level cross-cutting changes",
      "prompt_append": "Explora a fondo antes de implementar. Cambios pequeños y verificables."
    }
  },

  "categories": {
    "visual-engineering": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "medium"
    },
    "ultrabrain": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max"
    },
    "deep": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high"
    },
    "quick": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "low"
    },
    "unspecified-low": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "low"
    },
    "unspecified-high": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high"
    },
    "writing": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "medium"
    },
    "artistry": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high"
    }
  }
}
