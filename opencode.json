{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "lsp": {
    "oxlint": {
      "command": [
        "pnpm",
        "exec",
        "oxlint",
        "--ignore-pattern=node_modules",
        "--lsp"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".ts",
        ".tsx",
        ".mts",
        ".cts"
      ]
    },
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=8192"
      }
    }
  },
  "mcp": {
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh_grep": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "github": {
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:COMPOSER_AUTH_TOKEN}"
      },
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp"
    },
    "nuxt": {
      "enabled": true,
      "type": "remote",
      "url": "https://nuxt.com/mcp"
    }
  },
  "plugin": [
    "@slkiser/opencode-quota@latest",
    "@tarquinen/opencode-dcp@latest",
    "oh-my-openagent@latest"
  ],
  "provider": {
    "github-copilot": {
      "options": {
        "setCacheKey": true
      }
    },
    "openai": {
      "options": {
        "setCacheKey": true
      }
    },
    "opencode": {
      "options": {
        "setCacheKey": true
      }
    },
    "opencode-go": {
      "options": {
        "setCacheKey": true
      }
    },
    "openrouter": {
      "options": {
        "setCacheKey": true
      }
    }
  }
}
