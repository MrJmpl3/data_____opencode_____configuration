{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "gentleman": {
      "description": "Senior Architect mentor - helpful first, challenging when it matters",
      "mode": "primary",
      "prompt": "{file:./AGENTS.md}",
      "tools": {
        "edit": true,
        "write": true
      }
    }
  },
  "lsp": {
    "basedpyright": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"]
    },
    "bash-language-server": {
      "command": ["bash-language-server", "start"],
      "extensions": [".sh", ".bash", ".zsh"]
    },
    "intelephense": {
      "command": ["intelephense", "--stdio"],
      "extensions": [".php", ".phtml"]
    },
    "marksman": {
      "command": ["marksman"],
      "extensions": [".md"]
    },
    "tailwindcss-language-server": {
      "command": ["tailwindcss-language-server", "--stdio"],
      "extensions": [".css", ".scss", ".less", ".html", ".js", ".jsx", ".ts", ".tsx", ".vue", ".md", ".php"]
    },
    "taplo": {
      "command": ["taplo", "lsp", "stdio"],
      "extensions": [".toml"]
    },
    "typescript-language-server": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs"]
    },
    "vscode-css-language-server": {
      "command": ["vscode-css-language-server", "--stdio"],
      "extensions": [".css", ".scss", ".less"]
    },
    "vscode-eslint-language-server": {
      "command": ["vscode-eslint-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs", ".vue"]
    },
    "vscode-html-language-server": {
      "command": ["vscode-html-language-server", "--stdio"],
      "extensions": [".html", ".htm"]
    },
    "vscode-json-language-server": {
      "command": ["vscode-json-language-server", "--stdio"],
      "extensions": [".json", ".jsonc"]
    },
    "vue-language-server": {
      "command": ["vue-language-server", "--stdio"],
      "extensions": [".vue"]
    },
    "yaml-language-server": {
      "command": ["yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"]
    }
  },
  "mcp": {
    "ast_grep": {
      "command": ["ast-grep-mcp"],
      "enabled": true,
      "timeout": 30000,
      "type": "local"
    },
    "codegraph": {
      "command": ["codegraph", "serve", "--mcp"],
      "enabled": true,
      "type": "local"
    },
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "deepwiki": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "docker": {
      "command": ["uvx", "mcp-server-docker"],
      "enabled": true,
      "type": "local"
    },
    "engram": {
      "command": ["engram", "mcp", "--tools=agent"],
      "type": "local"
    },
    "github": {
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      },
      "oauth": false,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "grep_app": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "next": {
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
      "enabled": true,
      "type": "local"
    }
  },
  "model": "opencode-go/deepseek-v4-flash",
  "plugin": ["./plugins/hashline/index.ts"],
  "share": "disabled",
  "small_model": "opencode-go/deepseek-v4-flash"
}
